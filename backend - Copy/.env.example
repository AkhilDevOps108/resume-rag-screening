# Backend Environment Configuration
# Copy this to .env and customize as needed

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_FORCE_LOCAL=false
# Alternative models:
# - sentence-transformers/all-mpnet-base-v2 (larger, better quality)
# - sentence-transformers/all-distilroberta-v1 (faster)
# - sentence-transformers/all-bert-base-mean-tokens (smaller)

# Vector Store Configuration
USE_FAISS=true
FAISS_INDEX_TYPE=IndexFlatL2  # or IndexIVFFlat for large datasets

# Retrieval Configuration
DEFAULT_TOP_K=5
HYBRID_ALPHA=0.7  # 0.7 = 70% dense, 30% BM25
SEMANTIC_SIMILARITY_THRESHOLD=0.5

# Context Optimization
ENABLE_COMPRESSION=true
ENABLE_DEDUPLICATION=true
MIN_RELEVANCE_SCORE=0.3
MAX_CONTEXT_TOKENS=4000

# Graph Configuration
ENABLE_SEMANTIC_GRAPH=true
GRAPH_HOPS=2
GRAPH_SIMILARITY_THRESHOLD=0.5

# Gemini API (recommended for this project)
GEMINI_API_KEY=AIz
# You can also use GOOGLE_API_KEY or GOOGLE_GENAI_API_KEY.
# Do not commit real keys.
GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_API_KEY=
# COHERE_API_KEY=

# Storage
DATA_DIR=./data
CACHE_DIR=./.cache

# Logging
LOG_FILE=logs/rag.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
