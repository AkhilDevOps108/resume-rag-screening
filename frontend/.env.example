# Frontend Environment Configuration
# Copy this to .env and customize as needed

# API Configuration
REACT_APP_API_URL=http://localhost:8000/api

# Feature Flags
REACT_APP_DEBUG=false
REACT_APP_ENABLE_METRICS=true
REACT_APP_ENABLE_COMPARISON=true

# UI Configuration
REACT_APP_THEME=light  # light or dark
REACT_APP_PAGE_SIZE=10
REACT_APP_AUTO_REFRESH_METRICS=true
REACT_APP_REFRESH_INTERVAL=5000  # milliseconds

# Performance
REACT_APP_LAZY_LOAD_CHARTS=true
REACT_APP_DEBOUNCE_SEARCH=300  # milliseconds
